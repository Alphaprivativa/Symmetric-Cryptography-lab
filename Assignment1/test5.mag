procedure test5()
	index:=RealField(5)!0.065;
	error if Kasiski(C3,index) ne 6, "The result for C3 is not correct!\n";
	error if Kasiski(C5,index) ne 6, "The result for C5 is not correct!\n";
	"The function is correct!\n Can you recover the key used for C5 and its plaintext?\n";
end procedure;
