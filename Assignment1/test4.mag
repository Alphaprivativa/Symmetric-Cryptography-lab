	for i in [1..4] do 
		F,b:=Frequencies(LIST[i]);
		for j in [1..26] do 
			if Abs(F[j]-Freq[i][j]) gt 0.0001 then 
			error "The frequencies are not computed correctly!\n";
			end if;
		end for;
		if Abs(b-indeces[i]) gt 0.001 then 
			error "The index is not correct!\n";
		end if;
	end for; 
	"The function works properly!\n";
end procedure; 
